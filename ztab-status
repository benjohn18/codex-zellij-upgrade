#!/usr/bin/env python3
import json
import re
import subprocess
import sys


SUFFIX_RE = re.compile(r"\s+\[(?:ing|done|!!!)\]$")


def run(cmd):
    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)


def current_tab():
    proc = run(["zellij", "action", "list-tabs", "--json", "--all", "--state"])
    if proc.returncode != 0:
        return None, None
    try:
        data = json.loads(proc.stdout)
    except json.JSONDecodeError:
        return None, None

    if isinstance(data, dict):
        tabs = data.get("tabs") or data.get("Tabs") or []
    else:
        tabs = data

    for tab in tabs:
        if not isinstance(tab, dict):
            continue
        active = (
            tab.get("active")
            or tab.get("is_active")
            or tab.get("focused")
            or tab.get("is_focused")
            or tab.get("is_current")
        )
        if active:
            tab_id = tab.get("id") or tab.get("tab_id") or tab.get("position")
            name = tab.get("name") or tab.get("tab_name") or f"tab-{tab_id}"
            return str(tab_id), str(name)

    return None, None


def strip_status(name):
    return SUFFIX_RE.sub("", name).strip()


def main():
    if len(sys.argv) == 2 and sys.argv[1] == "--print-current":
        tab_id, current_name = current_tab()
        if not tab_id:
            sys.exit(1)
        print(f"{tab_id}\t{current_name}")
        return

    if len(sys.argv) < 2 or sys.argv[1] in {"-h", "--help"}:
        print("usage: ztab-status ing|done|!!!|clear [base-name]", file=sys.stderr)
        sys.exit(2)

    status = sys.argv[1]
    if status not in {"ing", "done", "!!!", "clear"}:
        print("status must be: ing, done, !!!, clear", file=sys.stderr)
        sys.exit(2)

    tab_id, current_name = current_tab()
    base = " ".join(sys.argv[2:]).strip() if len(sys.argv) > 2 else strip_status(current_name or "tab")
    new_name = base if status == "clear" else f"{base} [{status}]"

    if tab_id and tab_id not in {"None", ""}:
        proc = run(["zellij", "action", "rename-tab-by-id", tab_id, new_name])
    else:
        proc = run(["zellij", "action", "rename-tab", new_name])

    if proc.returncode != 0:
        sys.stderr.write(proc.stderr or proc.stdout)
        sys.exit(proc.returncode)


if __name__ == "__main__":
    main()
