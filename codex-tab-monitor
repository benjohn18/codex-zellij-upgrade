#!/usr/bin/env python3
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path


SUFFIX_RE = re.compile(r"\s+\[(?:ing|done|!!!)\]$")


def run(cmd):
    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)


def rename(tab_id: str, base_name: str, marker: str):
    clean = SUFFIX_RE.sub("", base_name).strip() or "codex"
    name = f"{clean} [{marker}]"
    run(["zellij", "action", "rename-tab-by-id", str(tab_id), name])


def classify_screen(text: str) -> str | None:
    if not text:
        return None
    if (
        "Would you like to run the following command?" in text
        and ("Yes, proceed" in text or "Press enter to confirm" in text or "Reason:" in text)
    ):
        return "!!!"
    if "Working (" in text and "esc to interrupt" in text:
        return "ing"
    if "Worked for" in text:
        return "done"
    return None


def dump_pane_screen(pane_id: str) -> str:
    if not pane_id:
        return ""
    proc = run(["zellij", "action", "dump-screen", "--pane-id", str(pane_id)])
    if proc.returncode != 0:
        return ""
    return proc.stdout


def newest_session(root: Path, start_epoch: float) -> Path | None:
    files = [p for p in root.glob("**/*.jsonl") if p.stat().st_mtime >= start_epoch - 5]
    if not files:
        return None
    return max(files, key=lambda p: p.stat().st_mtime)


def load_events(path: Path):
    try:
        with path.open("r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    yield json.loads(line)
                except json.JSONDecodeError:
                    continue
    except FileNotFoundError:
        return


def is_approval_request(payload) -> bool:
    args = payload.get("arguments") or ""
    if not isinstance(args, str):
        return False
    try:
        parsed = json.loads(args)
    except json.JSONDecodeError:
        return False
    return parsed.get("sandbox_permissions") == "require_escalated"


def classify_events(events) -> str:
    last_started_turn = None
    last_done_turn = None
    approval_waiting = False

    for event in events:
        etype = event.get("type")
        payload = event.get("payload") or {}

        if etype == "event_msg":
            ptype = payload.get("type")
            if ptype == "task_started":
                last_started_turn = payload.get("turn_id")
                last_done_turn = None
                approval_waiting = False
            elif ptype == "task_complete":
                last_done_turn = payload.get("turn_id")
                approval_waiting = False

        if etype == "response_item":
            rtype = payload.get("type")
            if rtype == "function_call":
                if is_approval_request(payload):
                    approval_waiting = True
            elif rtype == "function_call_output":
                approval_waiting = False

    if approval_waiting:
        return "!!!"
    if last_started_turn and last_started_turn != last_done_turn:
        return "ing"
    return "done"


def classify(path: Path) -> str:
    return classify_events(load_events(path))


def ev(etype, payload):
    return {"type": etype, "payload": payload}


def self_test():
    approval_args = json.dumps({"cmd": "cp a b", "sandbox_permissions": "require_escalated"})
    normal_args_with_words = json.dumps({"cmd": "grep sandbox_permissions approval file"})
    cases = [
        ("start -> ing", [ev("event_msg", {"type": "task_started", "turn_id": "t1"})], "ing"),
        (
            "start complete -> done",
            [
                ev("event_msg", {"type": "task_started", "turn_id": "t1"}),
                ev("event_msg", {"type": "task_complete", "turn_id": "t1"}),
            ],
            "done",
        ),
        (
            "approval request -> !!!",
            [
                ev("event_msg", {"type": "task_started", "turn_id": "t1"}),
                ev("response_item", {"type": "function_call", "arguments": approval_args, "call_id": "c1"}),
            ],
            "!!!",
        ),
        (
            "approval output -> ing",
            [
                ev("event_msg", {"type": "task_started", "turn_id": "t1"}),
                ev("response_item", {"type": "function_call", "arguments": approval_args, "call_id": "c1"}),
                ev("response_item", {"type": "function_call_output", "call_id": "c1", "output": "ok"}),
            ],
            "ing",
        ),
        (
            "approval output complete -> done",
            [
                ev("event_msg", {"type": "task_started", "turn_id": "t1"}),
                ev("response_item", {"type": "function_call", "arguments": approval_args, "call_id": "c1"}),
                ev("response_item", {"type": "function_call_output", "call_id": "c1", "output": "ok"}),
                ev("event_msg", {"type": "task_complete", "turn_id": "t1"}),
            ],
            "done",
        ),
        (
            "grep words do not trigger approval",
            [
                ev("event_msg", {"type": "task_started", "turn_id": "t1"}),
                ev("response_item", {"type": "function_call", "arguments": normal_args_with_words}),
            ],
            "ing",
        ),
        (
            "new task clears old approval",
            [
                ev("response_item", {"type": "function_call", "arguments": approval_args}),
                ev("event_msg", {"type": "task_started", "turn_id": "t2"}),
            ],
            "ing",
        ),
    ]
    failed = 0
    for name, events, want in cases:
        got = classify_events(events)
        if got != want:
            print(f"FAIL {name}: got {got}, want {want}", file=sys.stderr)
            failed += 1
        else:
            print(f"ok {name}: {got}")

    screen_cases = [
        (
            "screen approval prompt",
            "Would you like to run the following command?\nReason: x\n1. Yes, proceed (y)\nPress enter to confirm",
            "!!!",
        ),
        ("screen working", "Working (24s • esc to interrupt)", "ing"),
        ("screen worked", "Worked for 2m 39s", "done"),
        ("screen none", "ordinary shell text", None),
    ]
    for name, text, want in screen_cases:
        got = classify_screen(text)
        if got != want:
            print(f"FAIL {name}: got {got}, want {want}", file=sys.stderr)
            failed += 1
        else:
            print(f"ok {name}: {got}")
    return failed


def main():
    if len(sys.argv) == 2 and sys.argv[1] == "--self-test":
        sys.exit(self_test())

    if len(sys.argv) not in {4, 5}:
        print("usage: codex-tab-monitor <tab-id> <base-name> <start-epoch> [pane-id]", file=sys.stderr)
        sys.exit(2)

    tab_id, base_name, start_raw = sys.argv[1], sys.argv[2], sys.argv[3]
    pane_id = sys.argv[4] if len(sys.argv) == 5 else ""
    start_epoch = float(start_raw)
    root = Path(os.environ.get("CODEX_STATUS_ROOT", "~/.codex/sessions")).expanduser()
    last_marker = None

    while True:
        path = newest_session(root, start_epoch)
        marker = classify_screen(dump_pane_screen(pane_id))
        if marker is None:
            marker = "ing" if path is None else classify(path)
        if marker != last_marker:
            rename(tab_id, base_name, marker)
            last_marker = marker
        time.sleep(1)


if __name__ == "__main__":
    main()
